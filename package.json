{
  "name": "e-repairhub",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "build:backend": "npm run build -w @e-repairhub/backend",
    "start:backend": "npm run start -w @e-repairhub/backend",
    "dev:backend": "npm run dev -w @e-repairhub/backend",
    "dev:admin": "npm run dev -w admin-app",
    "dev:franchise": "npm run dev -w franchise-app",
    "build:franchise": "npm run build -w franchise-app",
    "dev:customer": "npm run dev -w customer-app",
    "dev:delivery": "npm run dev -w delivery-app",
    "seed:users": "npm run seed:users -w @e-repairhub/backend"
  },
  "dependencies": {
    "zustand": "^5.0.13"
  }
}
